[init]
  defaultBranch = main

[pull]
  ff = only

[push]
  default = current

[alias]
  lgl = log --graph --pretty='format:"%Cgreen%H %Creset%an | %s %Cred%d"'
  lg = log --graph --pretty='format:"%Cgreen%h %Creset%an | %s %Cred%d"'
  l = log --pretty='format:"%Cgreen%h %Creset%s %Cblue%an"' -n 10 

[diff]
    tool = nvimdiff
[difftool "nvimdiff"]
    cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
